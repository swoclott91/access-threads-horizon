{% doc %}
  AT: Bulk order grid nested modal for quick-add context.

  Renders a standalone `<dialog>` element that opens on top of the quick-add modal,
  providing a "modal-in-modal" bulk order experience from product cards on any page
  (home, collection, etc.).

  Intended to be placed once inside quick-add-modal.liquid via an AT CUSTOM block.
  Opened programmatically by at-bulk-grid.js when a [data-at-bulk-grid-trigger]
  is clicked inside #quick-add-modal-content.

  The dialog is a native <dialog> (not dialog-component) so it enters the browser
  top layer independently and stacks above the quick-add modal.
{% enddoc %}

{{ 'at-bulk-grid.css' | asset_url | stylesheet_tag }}
<script src="{{ 'at-bulk-grid.js' | asset_url }}?v=2" type="module"></script>

<dialog
  id="at-bulk-grid-quick-add-dialog"
  class="at-bulk-grid-modal color-{{ settings.popover_color_scheme }}"
  aria-labelledby="at-bulk-grid-quick-add-title"
>
  <div class="at-bulk-grid-modal__inner">
    <div class="at-bulk-grid-modal__header">
      <h2 id="at-bulk-grid-quick-add-title" class="at-bulk-grid-modal__title">Bulk Order</h2>
      <button
        type="button"
        id="at-bulk-grid-quick-add-close"
        class="button button-unstyled close-button at-bulk-grid-modal__close"
        aria-label="{{ 'accessibility.close_dialog' | t }}"
      >
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
    </div>
    <div
      class="at-bulk-grid at-bulk-grid--quick-add"
      data-at-bulk-grid
      data-at-bulk-add-to-cart-animation="{{ settings.add_to_cart_animation }}"
    ></div>
  </div>
</dialog>

{% stylesheet %}
  .at-bulk-grid-modal {
    padding: 0;
    border: var(--style-border-popover);
    border-radius: var(--style-border-radius-popover);
    background-color: var(--color-background);
    box-shadow: 0 8px 40px rgb(0 0 0 / var(--opacity-15));
    overflow: hidden;
    width: min(72rem, calc(100vw - 2rem));
    max-height: min(90dvh, 700px);
    display: flex;
    flex-direction: column;

    @media screen and (max-width: 749px) {
      position: fixed;
      margin: auto 0 0 0;
      width: 100%;
      max-width: 100%;
      border-radius: 0;
      border-top-left-radius: var(--style-border-radius-popover);
      border-top-right-radius: var(--style-border-radius-popover);
      max-height: 90dvh;
    }
  }

  .at-bulk-grid-modal[open] {
    animation: modalSlideInTop var(--animation-speed) var(--animation-easing) forwards;
  }

  .at-bulk-grid-modal.dialog-closing {
    animation: modalSlideOutTop var(--animation-speed) var(--animation-easing) forwards;
  }

  .at-bulk-grid-modal__inner {
    display: flex;
    flex-direction: column;
    flex: 1 1 0;
    min-height: 0;
    overflow-y: auto;
    padding: var(--padding-4xl) var(--padding-xl) var(--padding-xl);

    @media screen and (min-width: 750px) {
      padding: var(--padding-5xl);
    }
  }

  .at-bulk-grid-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-sm);
    margin-block-end: var(--gap-md);
    padding-inline-end: calc(var(--padding-2xl) + var(--minimum-touch-target) / 2);
  }

  .at-bulk-grid-modal__title {
    font-size: var(--font-size--xl);
    font-weight: 600;
    margin: 0;
  }

  .at-bulk-grid-modal__close {
    position: absolute;
    top: var(--margin-2xs);
    right: var(--margin-2xs);
    z-index: var(--layer-raised);
    transition: transform 0.15s var(--animation-timing-bounce);
    transform-origin: center;
    overflow: visible;
  }

  .at-bulk-grid-modal__close:active {
    transform: scale(0.99) translateY(1px);
  }

  .at-bulk-grid-modal__close:focus-visible {
    outline: none;
  }

  .at-bulk-grid-modal__close:focus-visible::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: calc(var(--style-border-radius-popover) - var(--margin-2xs));
    outline: var(--focus-outline-width) solid currentColor;
  }

  /* Sticky actions footer in quick-add context */
  .at-bulk-grid--quick-add .at-bulk-grid__actions[data-at-bulk-has-quantity='true'],
  .at-bulk-grid--quick-add .at-bulk-grid__actions.at-bulk-grid__actions--has-quantity {
    position: sticky;
    bottom: 0;
    z-index: 2;
    margin-top: auto;
    padding-block-start: var(--gap-md);
    padding-block-end: var(--padding-xs);
    background: var(--color-background);
    box-shadow: 0 -1px 0 var(--color-border);
  }

  @media screen and (max-width: 749px) {
    .at-bulk-grid-modal__inner {
      flex: 1 1 0;
      min-height: 0;
    }

    .at-bulk-grid--quick-add {
      flex: 1 1 0;
      min-height: 0;
      display: flex;
      flex-direction: column;
    }
  }
{% endstylesheet %}
