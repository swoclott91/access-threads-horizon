{%- doc -%}
  AT Menu – Mobile Drawer (view-stack architecture)

  Renders inside the <header-drawer>'s .menu-drawer container.
  Uses <at-menu-panel> custom element for multi-view navigation:
    – main       : top-level nav items from the main menu
    – categories : category sidebar items from at_categories_menu
    – brands     : brand grid with search + A-Z
    – cat-{handle}: sub-links for each category with children

  Close buttons use header-drawer/close so the stock component
  handles focus-trap teardown and details[open] reset.

  @param {object}  section              - The block object (for settings).
  @param {array}   menu_links           - Top-level links from the main nav.
  @param {object}  panel_link           - The nav link that triggers the categories panel.
  @param {string}  panel_handle         - Handle of the panel trigger item.
  @param {object}  categories_linklist  - Linklist for the categories sidebar.
  @param {object}  brands_linklist      - Linklist for the brand grid.
  @param {string}  brands_handle        - Handle of the brands category.
  @param {string}  highlight_handle     - Handle of the highlighted item.
  @param {string}  mobile_drawer_label  - Heading shown in the main view.
{%- enddoc -%}

{%- liquid
  assign icon_source    = section.settings.at_brand_icon_source | default: 'auto'
  assign show_search    = section.settings.at_show_brand_search
  assign mobile_cols    = section.settings.at_brands_mobile_columns | default: 2
  assign img_radius     = section.settings.at_brand_image_border_radius | default: 4
  assign drawer_heading = mobile_drawer_label | default: 'Shop'

  # Resolve the brands link from the categories linklist
  assign brands_cat_link = nil
  if categories_linklist != blank
    for cat_link in categories_linklist.links
      if cat_link.handle == brands_handle
        assign brands_cat_link = cat_link
        break
      endif
    endfor
  endif

  # Brand source: prefer dedicated brands linklist, fall back to category sub-links
  assign brand_source_links = blank
  if brands_linklist != blank
    assign brand_source_links = brands_linklist.links
  elsif brands_cat_link != blank
    assign brand_source_links = brands_cat_link.links
  endif

  assign brand_total = 0
  if brand_source_links != blank
    assign brand_total = brand_source_links.size
  endif

  # Build alphabet array from brand links
  assign all_letters = ''
  if brand_source_links != blank
    for brand_link in brand_source_links
      assign letter = brand_link.title | upcase | slice: 0, 1
      unless all_letters contains letter
        assign all_letters = all_letters | append: letter | append: ','
      endunless
    endfor
  endif
  assign alpha_letters = all_letters | split: ','
-%}

<at-menu-panel class="at-panel">

  {%- comment -%} ═══════════════════════════════════════════════════════════
    VIEW: Main
    Inlines the categories from at_categories_menu directly so users see
    Brands, T-Shirts, Polos, etc. without an extra "Products" drill-down.
    Non-panel menu items (Services, Contact, etc.) are appended below.
  ═══════════════════════════════════════════════════════════════════════ {%- endcomment -%}
  <div class="at-panel__view" data-view="main">

    <div class="at-panel__header">
      <h2 class="at-panel__title">{{- drawer_heading | escape -}}</h2>
      <button
        type="button"
        class="at-panel__close"
        aria-label="{{ 'actions.close' | t | default: 'Close menu' }}"
        on:click="header-drawer/close"
      >
        <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
      </button>
    </div>

    <nav class="at-panel__body" aria-label="{{ drawer_heading | escape }}">
      <ul class="at-panel__list" role="list">

        {%- comment -%} ── Category items (inlined from at_categories_menu) ── {%- endcomment -%}
        {%- if categories_linklist != blank -%}
          {%- for cat_link in categories_linklist.links -%}
            {%- liquid
              assign is_brands = false
              if cat_link.handle == brands_handle
                assign is_brands = true
              endif
              assign is_highlight = false
              if cat_link.handle == highlight_handle
                assign is_highlight = true
              endif
            -%}
            <li class="at-panel__list-item" style="--at-panel-index: {{ forloop.index }};">
              {%- if is_brands and brand_source_links != blank -%}
                <button
                  type="button"
                  class="at-panel__item{% if is_highlight %} at-panel__item--highlight{% endif %}"
                  on:click="/navigate"
                  data-target="brands"
                >
                  <span class="at-panel__item-text">{{- cat_link.title -}}</span>
                  <span class="at-panel__chevron svg-wrapper" aria-hidden="true">
                    {{- 'icon-chevron-right.svg' | inline_asset_content -}}
                  </span>
                </button>

              {%- elsif cat_link.links != blank -%}
                <button
                  type="button"
                  class="at-panel__item{% if is_highlight %} at-panel__item--highlight{% endif %}"
                  on:click="/navigate"
                  data-target="cat-{{ cat_link.handle }}"
                >
                  <span class="at-panel__item-text">{{- cat_link.title -}}</span>
                  <span class="at-panel__chevron svg-wrapper" aria-hidden="true">
                    {{- 'icon-chevron-right.svg' | inline_asset_content -}}
                  </span>
                </button>

              {%- else -%}
                <a
                  href="{{ cat_link.url }}"
                  class="at-panel__item{% if is_highlight %} at-panel__item--highlight{% endif %}"
                  {% if cat_link.current %}aria-current="page"{% endif %}
                >
                  <span class="at-panel__item-text">{{- cat_link.title -}}</span>
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        {%- endif -%}

        {%- comment -%} ── Remaining main menu items (skip the panel trigger) ── {%- endcomment -%}
        {%- for link in menu_links -%}
          {%- if link.handle == panel_handle -%}
            {%- continue -%}
          {%- endif -%}
          <li class="at-panel__list-item" style="--at-panel-index: {{ forloop.index | plus: categories_linklist.links.size }};">
            {%- if link.links != blank -%}
              <details class="at-panel__accordion">
                <summary class="at-panel__item">
                  <span class="at-panel__item-text">{{- link.title -}}</span>
                  <span class="at-panel__chevron at-panel__accordion-icon svg-wrapper" aria-hidden="true">
                    {{- 'icon-chevron-right.svg' | inline_asset_content -}}
                  </span>
                </summary>
                <ul class="at-panel__sub-list" role="list">
                  {%- for sub_link in link.links -%}
                    <li>
                      <a
                        href="{{ sub_link.url }}"
                        class="at-panel__sub-item"
                        {% if sub_link.current %}aria-current="page"{% endif %}
                      >
                        {{- sub_link.title -}}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </details>

            {%- else -%}
              <a
                href="{{ link.url }}"
                class="at-panel__item{% if link.handle == highlight_handle %} at-panel__item--highlight{% endif %}"
                {% if link.current %}aria-current="page"{% endif %}
              >
                <span class="at-panel__item-text">{{- link.title -}}</span>
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}

      </ul>
    </nav>
  </div>


  {%- comment -%} ═══════════════════════════════════════════════════════════
    VIEW: Brands
    Search bar, A-Z brand grid with avatars, pinned alphabet quick-jump.
  ═══════════════════════════════════════════════════════════════════════ {%- endcomment -%}
  {%- if brand_source_links != blank -%}
    <div class="at-panel__view at-panel__view--brands" data-view="brands" hidden>

      <div class="at-panel__header">
        <button
          type="button"
          class="at-panel__back"
          aria-label="{{ 'actions.back' | t | default: 'Back' }}"
          on:click="/back"
        >
          <span class="svg-wrapper">{{- 'icon-chevron-left.svg' | inline_asset_content -}}</span>
        </button>
        <h2 class="at-panel__title">{{- brands_cat_link.title | default: 'Brands' | escape -}}</h2>
        <button
          type="button"
          class="at-panel__close"
          aria-label="{{ 'actions.close' | t | default: 'Close menu' }}"
          on:click="header-drawer/close"
        >
          <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
        </button>
      </div>

      {%- if show_search -%}
        <div class="at-panel__search-wrapper" role="search">
          <span class="at-panel__search-icon svg-wrapper" aria-hidden="true">
            {{- 'icon-search.svg' | inline_asset_content -}}
          </span>
          <label for="at-panel-brand-search" class="visually-hidden">
            {{ 'content.search' | t | default: 'Search brands' }}
          </label>
          <input
            ref="searchInput"
            id="at-panel-brand-search"
            type="search"
            class="at-panel__search"
            placeholder="{{ 'placeholders.search' | t | default: 'Search brands…' }}"
            autocomplete="off"
            aria-controls="at-panel-brands-body"
            aria-label="{{ 'content.search' | t | default: 'Search brands' }}"
          >
          <button
            ref="searchClear"
            type="button"
            class="at-panel__search-clear"
            aria-label="{{ 'actions.clear' | t | default: 'Clear' }}"
            hidden
          >
            <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
          </button>
        </div>
      {%- endif -%}

      <span
        ref="brandCount"
        class="at-panel__brand-count"
        aria-live="polite"
        aria-atomic="true"
      >
        {{- brand_total -}}
      </span>

      <div
        class="at-panel__body"
        id="at-panel-brands-body"
        ref="brandsBody"
        role="list"
        aria-label="{{ brands_cat_link.title | default: 'Brands' }}"
        style="--at-brands-mobile-cols: {{ mobile_cols }};"
      >
        {%- if brand_source_links == blank -%}
          <p class="at-panel__empty">No brands found.</p>
        {%- else -%}
          {%- for letter in alpha_letters -%}
            {%- if letter != blank -%}
              {%- liquid
                assign letter_brand_count = 0
                for brand_link in brand_source_links
                  assign brand_first_letter = brand_link.title | upcase | slice: 0, 1
                  if brand_first_letter == letter
                    assign letter_brand_count = letter_brand_count | plus: 1
                  endif
                endfor
                assign grid_rows = 1
                if letter_brand_count > 0
                  assign grid_rows = letter_brand_count | plus: mobile_cols | minus: 1 | divided_by: mobile_cols
                endif
              -%}
              <div
                class="at-panel__letter-section"
                id="at-letter-{{ letter }}"
                role="listitem"
              >
                <div class="at-panel__letter-header" aria-hidden="true">{{- letter -}}</div>
                <div
                  class="at-panel__brand-grid"
                  style="--at-panel-brand-rows: {{ grid_rows }};"
                >
                  {%- for brand_link in brand_source_links -%}
                    {%- assign brand_first_letter = brand_link.title | upcase | slice: 0, 1 -%}
                    {%- if brand_first_letter == letter -%}
                      {%- liquid
                        assign brand_icon = blank

                        unless icon_source == 'initials_only'
                          if icon_source == 'auto'
                            assign brand_mobj = brand_link.object.metafields.custom.brand.value
                            if brand_mobj != blank
                              assign raw_icon = brand_mobj.icon
                              if raw_icon != blank
                                assign brand_icon = raw_icon
                              endif
                            endif
                          endif

                          if brand_icon == blank
                            assign coll_img = brand_link.object.featured_image
                            if coll_img != blank
                              assign brand_icon = coll_img
                            endif
                          endif
                        endunless
                      -%}
                      <a
                        href="{{ brand_link.url }}"
                        class="at-panel__brand-item"
                        data-brand-name="{{ brand_link.title | escape }}"
                        {% if brand_link.current %}aria-current="page"{% endif %}
                      >
                        <span
                          class="at-brand-avatar{% if brand_icon != blank %} at-brand-avatar--image{% else %} at-brand-avatar--initials{% endif %}"
                          style="--at-brand-avatar-radius: {{ img_radius }}px;"
                          aria-hidden="true"
                          data-brand-name="{{ brand_link.title | escape }}"
                        >
                          {%- if brand_icon != blank -%}
                            {{-
                              brand_icon
                              | image_url: width: 48, height: 48, crop: 'center'
                              | image_tag: alt: '', loading: 'lazy', width: 24, height: 24
                            -}}
                          {%- else -%}
                            {{- brand_link.title | slice: 0, 2 | upcase -}}
                          {%- endif -%}
                        </span>
                        <span class="at-panel__brand-name">{{- brand_link.title -}}</span>
                      </a>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if alpha_letters.size > 0 -%}
        <nav
          ref="alphaBar"
          class="at-panel__alpha-bar"
          aria-label="{{ 'accessibility.skip_to_results_list' | t | default: 'Jump to letter' }}"
        >
          {%- for letter in alpha_letters -%}
            {%- if letter != blank -%}
              <button
                type="button"
                class="at-panel__alpha-btn"
                data-letter="{{ letter }}"
                aria-label="{{ letter }}"
                on:click="/scrollToLetter"
              >
                {{- letter -}}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </nav>
      {%- endif -%}
    </div>
  {%- endif -%}


  {%- comment -%} ═══════════════════════════════════════════════════════════
    VIEWS: Category sub-pages
    One view per category that has children (excluding brands).
    Supports two layouts:
      – Grouped: sub-links nested 3-deep render with group headings
      – Flat: direct sub-links in a grid with optional collection images
  ═══════════════════════════════════════════════════════════════════════ {%- endcomment -%}
  {%- if categories_linklist != blank -%}
    {%- for cat_link in categories_linklist.links -%}
      {%- if cat_link.links != blank and cat_link.handle != brands_handle -%}
        {%- liquid
          # Detect if this category has grouped (3-level) children
          assign has_groups = false
          for sub_link in cat_link.links
            if sub_link.links != blank
              assign has_groups = true
              break
            endif
          endfor

          # Detect if children are collection links (render images)
          assign render_images = false
          assign cat_collection_links = cat_link.links | where: 'type', 'collection_link'
          assign cat_catalog_links = cat_link.links | where: 'type', 'catalog_link'
          if cat_collection_links.size > 0 or cat_catalog_links.size > 0
            assign render_images = true
          endif
        -%}
        <div class="at-panel__view" data-view="cat-{{ cat_link.handle }}" hidden>

          <div class="at-panel__header">
            <button
              type="button"
              class="at-panel__back"
              aria-label="{{ 'actions.back' | t | default: 'Back' }}"
              on:click="/back"
            >
              <span class="svg-wrapper">{{- 'icon-chevron-left.svg' | inline_asset_content -}}</span>
            </button>
            <h2 class="at-panel__title">{{- cat_link.title | escape -}}</h2>
            <button
              type="button"
              class="at-panel__close"
              aria-label="{{ 'actions.close' | t | default: 'Close menu' }}"
              on:click="header-drawer/close"
            >
              <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
            </button>
          </div>

          <div class="at-panel__body">
            {%- if has_groups -%}
              {%- comment -%} Grouped layout: children act as group headings {%- endcomment -%}
              {%- for group_link in cat_link.links -%}
                {%- if group_link.links != blank -%}
                  <div class="at-panel__group">
                    <h3 class="at-panel__group-title">{{- group_link.title -}}</h3>
                    <ul class="at-panel__grid{% if render_images %} at-panel__grid--images{% endif %}" role="list">
                      {%- for item_link in group_link.links -%}
                        <li>
                          <a
                            href="{{ item_link.url }}"
                            class="at-panel__grid-item"
                            {% if item_link.current %}aria-current="page"{% endif %}
                          >
                            {%- if render_images -%}
                              {%- render 'link-featured-image',
                                link: item_link,
                                class: 'at-panel__grid-image',
                                sizes: 'auto, 200px'
                              -%}
                            {%- endif -%}
                            <span class="at-panel__grid-item-text">{{- item_link.title -}}</span>
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                {%- else -%}
                  <a
                    href="{{ group_link.url }}"
                    class="at-panel__item at-panel__item--child"
                    {% if group_link.current %}aria-current="page"{% endif %}
                  >
                    <span class="at-panel__item-text">{{- group_link.title -}}</span>
                  </a>
                {%- endif -%}
              {%- endfor -%}

            {%- else -%}
              {%- comment -%} Flat layout: sub-links in a grid/list {%- endcomment -%}
              <ul class="at-panel__grid{% if render_images %} at-panel__grid--images{% endif %}" role="list">
                {%- for sub_link in cat_link.links -%}
                  <li>
                    <a
                      href="{{ sub_link.url }}"
                      class="at-panel__grid-item"
                      {% if sub_link.current %}aria-current="page"{% endif %}
                    >
                      {%- if render_images -%}
                        {%- render 'link-featured-image',
                          link: sub_link,
                          class: 'at-panel__grid-image',
                          sizes: 'auto, 200px'
                        -%}
                      {%- endif -%}
                      <span class="at-panel__grid-item-text">{{- sub_link.title -}}</span>
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}

            {%- if cat_link.url != blank -%}
              <div class="at-panel__view-all">
                <a href="{{ cat_link.url }}" class="at-panel__view-all-link">
                  Shop all {{ cat_link.title }} →
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

</at-menu-panel>
